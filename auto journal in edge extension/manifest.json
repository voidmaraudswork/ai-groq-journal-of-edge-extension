{
  "manifest_version": 3,
  "name": "DevFlow",
  "version": "1.0",
  "description": "Automated Developer Journal & Standup Prep Tool",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}